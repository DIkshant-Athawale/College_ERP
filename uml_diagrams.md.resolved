## 2. Component Diagram — System Architecture

```mermaid
graph TB
    subgraph Client["🖥️ Client Browser"]
        subgraph ReactApp["React SPA (Vite + TypeScript)"]
            Router["AppRoutes<br/>(react-router-dom)"]
            
            subgraph Pages["Pages"]
                Login["Login"]
                AdminDash["AdminDashboard"]
                StudentDash["StudentDashboard"]
                FacultyDash["FacultyDashboard"]
                NotFound["NotFound / Unauthorized"]
            end

            subgraph Components["Components"]
                Navbar["Navbar"]
                ProtectedRoute["ProtectedRoute"]
                ThemeSwitcher["ThemeSwitcher"]
                ErrorBoundary["ErrorBoundary"]
                
                subgraph StudentComps["Student Components"]
                    SPC["StudentProfileCard"]
                    SubjCard["SubjectsCard"]
                    FeeCard["FeeCard"]
                    AttBar["AttendanceBarSection"]
                    TTTable["TimetableTable"]
                end
                
                subgraph FacultyComps["Faculty Components"]
                    FPC["FacultyProfileCard"]
                    FCC["FacultyCoursesCard"]
                    FTT["FacultyTimetableTable"]
                end
            end

            subgraph Contexts["Contexts"]
                AuthCtx["AuthContext<br/>(login/logout/refresh)"]
                ThemeCtx["ThemeContext<br/>(dark/light)"]
            end

            subgraph APILayer["API Layer (Axios)"]
                AxiosInst["axios.ts<br/>(interceptors + refresh)"]
                AuthAPI["auth.ts"]
                StudentAPI["student.ts"]
                FacultyAPI["faculty.ts"]
                AdminAPIs["courses.ts | departments.ts<br/>teachers.ts | students.ts<br/>timetable.ts | statistics.ts"]
            end
        end
        LocalStorage["LocalStorage<br/>(JWT access token)"]
    end

    subgraph Backend["⚙️ Backend Server (Express, port 3000)"]
        ExpressApp["Express App<br/>(index.js)"]
        
        subgraph Middleware["Middleware"]
            AuthMW["authenticate<br/>(JWT verify)"]
            AuthzMW["authorize<br/>(role check)"]
        end
        
        subgraph Routes["Route Handlers"]
            AuthRoute["/login<br/>auth.js"]
            AdminRoute["/admin<br/>admin.js"]
            StudentRoute["/student<br/>student.js"]
            TeacherRoute["/teacher<br/>teacher.js"]
        end
    end

    subgraph Database["🗄️ MySQL (clg_db)"]
        Tables["11 Tables<br/>(see ER Diagram)"]
    end

    Router --> Pages
    Pages --> Components
    Pages --> Contexts
    Contexts --> APILayer
    APILayer --> LocalStorage
    APILayer -- "HTTP/REST + Cookie" --> ExpressApp
    ExpressApp --> Middleware
    Middleware --> Routes
    Routes -- "mysql2/promise<br/>pool (limit:10)" --> Tables
```

